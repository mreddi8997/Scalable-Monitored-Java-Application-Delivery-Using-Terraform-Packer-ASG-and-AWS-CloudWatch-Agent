pipeline {
    agent {
        // Targets a Jenkins agent node running natively on an EC2 instance
        label 'ec2-packer-runner' 
    }

    environment {
        ARTIFACT_NAME = "app.jar"
        AWS_REGION    = "us-east-2" // Update to your desired AWS region
    }

    stages {
        stage('1. Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('2. Build Java Application') {
            steps {
                echo 'Compiling Java code natively on the EC2 build agent...'
                // Assumes Maven and Java are installed on your EC2 agent node
                sh 'mvn clean package -DskipTests'
                
                echo 'Staging artifact for Packer processing...'
                sh "cp target/*.jar target/${ARTIFACT_NAME}"
            }
        }

        stage('3. Bake and Register AMI via Packer') {
            steps {
                echo 'Initializing Packer AWS plugins...'
                sh 'packer init java-app.pkr.hcl'

                echo 'Validating Packer configuration template...'
                sh 'packer validate java-app.pkr.hcl'

                echo 'Executing Packer build to bake image and register it in the AMI Catalog...'
                // Packer will read target/app.jar directly from the workspace
                sh 'packer build -var "aws_region=${AWS_REGION}" java-app.pkr.hcl'
            }
        }
    }

    post {
        always {
            echo 'Cleaning up build workspace resources...'
            cleanWs()
        }
    }
}